# =============================================================================
# Copie este arquivo para .env e preencha com valores reais:
#   cp .env.example .env
#
# NUNCA commite o arquivo .env com senhas reais.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_PASSWORD=ALTERE_ESTA_SENHA_FORTE

# --- n8n (mesma chave em editor, webhook e worker) ---
# Gere com: openssl rand -hex 32
N8N_ENCRYPTION_KEY=ALTERE_ESTA_CHAVE_32_BYTES_HEX

# --- Acesso por IP na rede privada (HTTP, sem HTTPS) ---
# Troque 192.168.1.100 pelo IP do servidor
N8N_HOST=192.168.1.100
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false
N8N_EDITOR_BASE_URL=http://192.168.1.100:5678/

WEBHOOK_PORT=5679
WEBHOOK_URL=http://192.168.1.100:5679/

# Jobs simultâneos do worker
N8N_WORKER_CONCURRENCY=10

# --- Portainer (opcional — docker-compose.portainer.yml) ---
PORTAINER_PORT=9000
